# Anamnesis — 4D Strategic Memory Engine
# Copy this file to .env and fill in your values

# ── Database (PostgreSQL + pgvector) ──
ANAMNESIS_DB_HOST=localhost
ANAMNESIS_DB_PORT=5432
ANAMNESIS_DB_NAME=anamnesis
ANAMNESIS_DB_USER=anamnesis
ANAMNESIS_DB_PASSWORD=anamnesis_dev

# ── Embeddings (choose one provider) ──
# Option 1: Voyage AI (recommended — Anthropic ecosystem, best quality)
ANAMNESIS_EMBEDDING_PROVIDER=voyage
ANAMNESIS_EMBEDDING_MODEL=voyage-3-lite
VOYAGE_API_KEY=your-voyage-api-key
# Get your key at: https://dashboard.voyageai.com/

# Option 2: Local embeddings (no API key needed, runs on device)
# ANAMNESIS_EMBEDDING_PROVIDER=local
# ANAMNESIS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LLM (for fact extraction + reflect synthesis) ──
# Option 1: Anthropic (recommended)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANAMNESIS_REFLECT_MODEL=claude-haiku-4-5-20251001

# Option 2: OpenAI
# OPENAI_API_KEY=your-openai-api-key
# ANAMNESIS_REFLECT_MODEL=gpt-4o-mini

# ── Server ──
ANAMNESIS_HOST=0.0.0.0
ANAMNESIS_PORT=8400
ANAMNESIS_API_KEY=  # Optional: set to require Bearer token auth

# ── Docker (only needed for docker compose) ──
POSTGRES_PASSWORD=anamnesis_dev
